# ──────────────────────────────────────────────
# Transport OS — Backend Environment Variables
# Copy this file to .env for local development.
# Add these keys in Vercel Dashboard → Project → Settings → Environment Variables
# ──────────────────────────────────────────────

# Optional: Supabase (for persistent storage — replace in-memory StorageEngine)
SUPABASE_URL=your-supabase-project-url
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: restrict CORS to your deployed frontend
ALLOWED_ORIGIN=https://your-admin-dashboard.vercel.app
